{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/betorrillo/football-data/main/schemas/teams_index.schema.json",
  "title": "teams/_index.json (brief §6.3)",
  "type": "object",
  "required": ["generated_at", "total", "by_competition", "teams"],
  "additionalProperties": false,
  "properties": {
    "generated_at": { "$ref": "_enums.json#/definitions/iso_datetime" },
    "total": { "type": "integer", "minimum": 0 },
    "by_competition": {
      "type": "object",
      "description": "Counts (or string notes) per competition. Keys are competition enums.",
      "additionalProperties": {
        "type": ["integer", "string"]
      }
    },
    "teams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "liga", "path"],
        "properties": {
          "slug": { "$ref": "_enums.json#/definitions/slug" },
          "liga": { "$ref": "_enums.json#/definitions/competition" },
          "path": { "type": "string", "pattern": "^teams/[a-z0-9-]+\\.json$" }
        }
      }
    }
  }
}
