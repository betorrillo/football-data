{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/betorrillo/football-data/main/schemas/manifest_agent.schema.json",
  "title": "manifest_agent.json (brief §7.2)",
  "description": "Single entry point for the Claude agent. Lists all upcoming matches in scope_window with readiness flags and precomputed highlights.",
  "type": "object",
  "required": ["generated_at", "scope_window", "matches", "global_resources", "scraper_meta"],
  "additionalProperties": false,
  "properties": {
    "generated_at": { "$ref": "_enums.json#/definitions/iso_datetime" },
    "scope_window": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "$ref": "_enums.json#/definitions/iso_datetime" },
        "to": { "$ref": "_enums.json#/definitions/iso_datetime" },
        "comment": { "type": "string" }
      }
    },
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "comp", "round", "home", "away", "kickoff_iso", "readiness", "resources", "highlights"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
          "comp": { "$ref": "_enums.json#/definitions/competition" },
          "round": { "type": "string" },
          "home": { "$ref": "_enums.json#/definitions/slug" },
          "away": { "$ref": "_enums.json#/definitions/slug" },
          "kickoff_iso": { "$ref": "_enums.json#/definitions/iso_datetime" },
          "readiness": {
            "type": "object",
            "required": [
              "context",
              "h2h",
              "referee_designated",
              "lineup_probables",
              "lineup_confirmed",
              "ready_for_v63_analysis",
              "missing_for_full_analysis"
            ],
            "properties": {
              "context": { "type": "boolean" },
              "h2h": { "type": "boolean" },
              "referee_designated": { "type": "boolean" },
              "lineup_probables": { "type": "boolean" },
              "lineup_confirmed": { "type": "boolean" },
              "ready_for_v63_analysis": { "type": "boolean" },
              "missing_for_full_analysis": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "resources": {
            "type": "object",
            "required": ["context", "h2h", "home_team", "away_team"],
            "properties": {
              "context": { "type": "string" },
              "h2h": { "type": "string" },
              "lineup": { "type": ["string", "null"] },
              "home_team": { "type": "string" },
              "away_team": { "type": "string" },
              "referee": { "type": ["string", "null"] }
            }
          },
          "highlights": {
            "type": "object",
            "properties": {
              "asimetria_motivacion": { "$ref": "_enums.json#/definitions/asimetria" },
              "eu_compromise_within_14d": {
                "type": "array",
                "items": { "type": "string" }
              },
              "emocional_tags": {
                "type": "array",
                "items": { "$ref": "_enums.json#/definitions/motivacion_emocional_tag" }
              },
              "ref_verdict": { "$ref": "_enums.json#/definitions/referee_verdict" }
            }
          }
        }
      }
    },
    "global_resources": {
      "type": "object",
      "properties": {
        "all_referees": { "type": "string" },
        "teams_index": { "type": "string" }
      }
    },
    "scraper_meta": {
      "type": "object",
      "required": ["version", "run_id"],
      "properties": {
        "version": { "type": "string", "pattern": "^v\\d+\\.\\d+(\\.\\d+)?$" },
        "run_id": { "type": "string" },
        "fuentes_failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
